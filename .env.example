# ─────────────────────────────────────────────
#  NOVA — Integrated CLI + Voice Assistant
#  Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

# ── LLM Providers ────────────────────────────
# Groq (free tier available — recommended primary)
GROQ_API_KEY=gsk_...

# OpenRouter (multi-model gateway, many free models)
OPENROUTER_API_KEY=sk-or-...

# Anthropic / Claude (optional — fallback)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI / GPT (optional — fallback)
OPENAI_API_KEY=sk-...

# ── Router / Budget ───────────────────────────
# Order to try providers: ollama, groq, openrouter, anthropic, openai
ROUTER_PROVIDER_ORDER=ollama,groq,openrouter

# Max USD to spend per session before warning
SESSION_BUDGET_USD=0.10
BUDGET_WARNING_THRESHOLD=0.80

# ── Ollama (local LLM — free, private) ───────
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1

# ── Obsidian / Cerebro ────────────────────────
# Path to your Obsidian vault (file-based search always works)
CEREBRO_VAULT=~/Cerebro

# Obsidian Local REST API plugin (optional)
# https://github.com/coddingtonbear/obsidian-local-rest-api
OBSIDIAN_BASE_URL=https://127.0.0.1:27124
OBSIDIAN_API_KEY=your_obsidian_api_key

# ── Assistant Identity ────────────────────────
ASSISTANT_NAME=Nova

# ── Wake Word / Voice ─────────────────────────
WAKE_WORD=nova
REQUIRE_WAKE_WORD=true
FOLLOWUP_WINDOW_SEC=22

# macOS TTS voice (Reed = Spanish, Alex = English)
NOVA_VOICE=Reed
NOVA_VOICE_RATE=185

# Edge TTS (optional — neural voices via edge-tts package)
EDGE_VOICE=es-AR-TomasNeural
EDGE_RATE=+0%
EDGE_PITCH=+0Hz

# ── STT / Audio ───────────────────────────────
BARGE_IN_THRESHOLD=0.015
NOISE_FILTER_FACTOR=1.5

# ── Memory ───────────────────────────────────
MAX_HISTORY=20

# ── Integrations ─────────────────────────────
# GitHub personal access token (for code_assistant agent)
GITHUB_TOKEN=ghp_...

# Telegram bot (for Nova notifications + bidirectional receive)
TELEGRAM_BOT_TOKEN=123456789:AAF...
TELEGRAM_CHAT_ID=your_chat_id
NOVA_TELEGRAM_PORT=7891        # Puerto del servidor Telegram Receive
NOVA_TELEGRAM_SERVER=1         # 0 para deshabilitar
NOVA_DIFF_CONFIRM=0            # 1 = pedir S/n antes de aplicar cambios a archivos (solo terminal)
NOVA_AUTO_TESTS=0              # 1 = generar y ejecutar tests pytest automáticamente al crear/editar archivos .py

# n8n automation server (optional)
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=your_webhook_secret

# Blender MCP server port (for Blender integration)
BLENDER_MCP_PORT=9876
