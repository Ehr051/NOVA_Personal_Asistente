def cmd_skill_info(name):
    """Mostrar información detallada de un skill"""
    try:
        # Import the skills module
        from nova.tools import nova_skills
        import inspect
        
        # Check if the skill exists
        skill_func = getattr(nova_skills, name, None)
        if not skill_func or not inspect.isfunction(skill_func):
            print(f"❌ Skill '{name}' no encontrado.")
            print("  Usa 'nova skill list' para ver los skills disponibles.")
            return 1
        
        # Get skill information
        print(f"ℹ️  Información del skill '{name}':")
        
        # Get function signature
        sig = inspect.signature(skill_func)
        params = list(sig.parameters.keys())
        
        if params:
            print(f"  Parámetros: {', '.join(params)}")
        else:
            print("  Parámetros: Ninguno")
        
        # Get docstring - try multiple methods
        doc = inspect.getdoc(skill_func)
        if not doc:
            # Try to get the source and extract docstring manually
            try:
                source = inspect.getsource(skill_func)
                # Look for docstring in the source
                lines = source.split('\n')
                in_docstring = False
                doc_lines = []
                for line in lines:
                    stripped = line.strip()
                    if stripped.startswith('"""') or stripped.startswith("'''"):
                        if not in_docstring:
                            in_docstring = True
                            # Check if it's a one-line docstring
                            if stripped.count('"""') == 2 or stripped.count("'''") == 2:
                                doc_content = stripped[3:-3] if stripped.startswith('"""') else stripped[3:-3]
                                if doc_content:
                                    doc_lines.append(doc_content)
                                break
                        else:
                            # End of docstring
                            break
                    elif in_docstring:
                        doc_lines.append(line)
                
                if doc_lines:
                    doc = '\n'.join(doc_lines).strip()
            except:
                pass
        
        if doc:
            # Clean up docstring for display - take first meaningful line
            doc_lines = [line.strip() for line in doc.split('\n') if line.strip()]
            if doc_lines:
                first_line = doc_lines[0]
                print(f"  Descripción: {first_line}")
            else:
                print("  Descripción: Sin descripción disponible")
        else:
            print("  Descripción: Sin documentación disponible")
            
        return 0
    except Exception as e:
        print(f"❌ Error al obtener información del skill: {e}")
        return 1

