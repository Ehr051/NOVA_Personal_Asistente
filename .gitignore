qdrant_db/
qdrant.lock

# Código legado - no incluir en repositorio principal
src/nova/legacy/

# PyInstaller build artifacts
build/
dist/
*.spec.bak

# Artefactos de test generados — no trackear
tests/reports/
tests/__pycache__/
tests/model_stats.json

# Notas de desarrollo local — no incluir en repositorio principal
*/workflow.md
docs/NOVA_ROADMAP.md
docs/WORKFLOW.md
docs/STATUS.md