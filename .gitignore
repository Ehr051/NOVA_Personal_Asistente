.env
launch_nova.bat
__pycache__/
*.pyc
*.pyo
.DS_Store
~/NovaOutput/

# Screenshots y capturas de auditoría (no van al repo)
*.jpeg
*.jpg
*.gif
*.webp
*.png
.playwright-mcp/

# Excepciones: assets del proyecto sí van al repo
!assets/*.png
